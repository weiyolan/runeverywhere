# Copy to .env and fill in. EXPO_PUBLIC_* values are embedded in the app bundle —
# only ever put the *anon* key here, never the service-role key.

# Supabase — from `supabase start` (local) or the project dashboard (hosted)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps native SDKs (react-native-maps, PROVIDER_GOOGLE) — one key per
# platform, restricted by bundle id / package name in Google Cloud console.
GOOGLE_MAPS_API_KEY_IOS=
GOOGLE_MAPS_API_KEY_ANDROID=

# Google sign-in OAuth clients (P1 G3) — public identifiers, safe to commit.
# Web client id is the id-token audience; iOS URL scheme is the reversed iOS
# client id (com.googleusercontent.apps.<id>), consumed by app.config.ts.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
GOOGLE_SIGNIN_IOS_URL_SCHEME=
